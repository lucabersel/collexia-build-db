# ── TCG API ───────────────────────────────────────────────────────────────────
# Chiave opzionale — senza chiave il limite è 1.000 req/giorno, con chiave 10.000
# Registrazione gratuita: https://dev.pokemontcg.io
TCG_API_KEY=

# ── Delay tra richieste (secondi) ─────────────────────────────────────────────
# Aumenta se ricevi errori 429 (Too Many Requests)
DEX_REQUEST_DELAY=0.05
CARDS_REQUEST_DELAY=0.1

# ── Viewer ────────────────────────────────────────────────────────────────────
VIEWER_PORT=5000